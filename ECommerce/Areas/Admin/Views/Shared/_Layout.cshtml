@{
    var fullname = User.FindFirst("FullName")?.Value;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ECommerce Admin</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=Playfair+Display:wght@600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/category.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/account.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ECommerce.styles.css" asp-append-version="true" />

    <style>
            /* Additional refinement to bridge your CSS with the Bootstrap Navbar */
            .navbar {
                background-color: var(--panel) !important;
                padding: 1rem 2rem;
                border-bottom: 1px solid var(--border) !important;
            }
            .navbar-brand {
                font-family: 'Playfair Display', serif;
                font-size: 1.5rem;
                color: var(--ink) !important;
                font-weight: 600;
            }
            .nav-link {
                font-family: 'DM Sans', sans-serif;
                font-weight: 500;
                color: var(--muted) !important;
                margin: 0 10px;
                font-size: 0.9rem;
                position: relative;
            }
            .nav-link:hover {
                color: var(--accent) !important;
            }
            /* Active indicator */
            .nav-item.active .nav-link, .nav-link:focus {
                color: var(--ink) !important;
            }
            body {
                background-color: var(--surface);
                color: var(--ink);
            }
            footer {
                background: var(--panel);
                padding: 20px 0;
                font-family: 'DM Sans', sans-serif;
                font-size: 0.85rem;
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm box-shadow mb-4">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="Admin" asp-controller="Home" asp-action="Index">
                    <i class="bi bi- bag-heart-fill me-2" style="color: var(--accent)"></i>Admin
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link custom-nav-link" asp-area="Admin" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link custom-nav-link" asp-area="Admin" asp-controller="Category" asp-action="Index">Category</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link custom-nav-link" asp-area="Admin" asp-controller="Product" asp-action="Index">Product</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link custom-nav-link" asp-area="Admin" asp-controller="Order" asp-action="Index">Orders</a>
                        </li>
                        @if (User.IsInRole("SuperAdmin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link px-3 text-dark custom-nav-link" asp-area="Admin" asp-controller="Users" asp-action="CreateAdmin">Create Admin</a>
                            </li>
                        }
                        @if (User.Identity?.IsAuthenticated ==true)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="profileDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    
                                    <span class="fw-medium text-dark">
                                        @fullname.ToUpper()
                                    </span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" aria-labelledby="profileDropdown">
                                    <li>
                                        <a class="dropdown-item py-2" asp-area="Identity" asp-page="/Account/Manage/Index">
                                            <i class="bi bi-person me-2 text-muted"></i> My Profile
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form class="form-inline" asp-area="" asp-controller="Account" asp-action="Logout" >
                                            <button type="submit" class="dropdown-item py-2 text-danger">
                                                <i class="bi bi-box-arrow-right me-2"></i> Logout
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">Login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="index-wrapper">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5">
        <div class="container text-center">
            &copy; 2026 — <span style="color: var(--ink); font-weight: 500;">ECommerce</span> —
            <a asp-area="" asp-controller="Home" asp-action="Privacy" class="custom-footer-link text-decoration-none">Privacy Policy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>