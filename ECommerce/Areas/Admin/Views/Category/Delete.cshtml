@model ECommerce.Presentation.Modules.Categories.ViewModels.CategoryEditVM

@{
    ViewData["Title"] = "Delete Category";
}

<div class="premium-wrapper">
    <div class="premium-card border-danger-subtle">
        <div class="premium-card-header">
            <div>
                <span class="premium-badge premium-badge-danger">Action Required</span>
                <h2 class="premium-title">Delete "@Model.Name"?</h2>
            </div>
        </div>

        <div class="premium-card-body">
            <div class="premium-alert premium-alert-danger">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="alert-icon"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                <div>
                    <strong>Warning:</strong> You are about to permanently delete this category. This action cannot be undone and will remove all associated data.
                </div>
            </div>

            <dl class="premium-datalist mt-4">
                <div class="data-group">
                    <dt>Category ID</dt>
                    <dd class="font-mono">@Html.DisplayFor(model => model.Id)</dd>
                </div>

                <div class="data-group">
                    <dt>Category Name</dt>
                    <dd>@Html.DisplayFor(model => model.Name)</dd>
                </div>

                <div class="data-group col-span-full">
                    <dt>Description</dt>
                    <dd class="data-description">@Html.DisplayFor(model => model.Description)</dd>
                </div>

                <div class="data-group">
                    <dt>Date Created</dt>
                    <dd>@Html.DisplayFor(model => model.CreateDate)</dd>
                </div>
            </dl>
        </div>

        <form asp-action="Delete" class="m-0">
            <input type="hidden" asp-for="Id" />

            <div class="premium-card-footer">
                <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="btn-premium btn-premium-ghost">
                    Cancel and Return
                </a>
                <button type="submit" class="btn-premium btn-premium-danger-solid">
                    Yes, Delete Category
                </button>
            </div>
        </form>
    </div>
</div>