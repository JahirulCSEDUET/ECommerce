@model ECommerce.Presentation.Modules.Categories.ViewModels.CategoryEditVM
@{
    ViewData["Title"] = "Edit Category";
}

<div class="premium-wrapper edit-wrapper">
    <div class="premium-card edit-card">
        <div class="edit-header">
            <div class="edit-header-icon">
                <svg viewBox="0 0 24 24">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                </svg>
            </div>
            <div class="edit-header-text">
                <h1>Edit Category</h1>
                <p>Update the details below and save your changes.</p>
            </div>
        </div>

        <div class="edit-body">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger form-validation-summary"></div>

                <input asp-for="Id" type="hidden" />
                <input asp-for="CreateDate" type="hidden" />

                <div class="form-group">
                    <label asp-for="Name" class="control-label"></label>
                    <input asp-for="Name" class="form-control" placeholder="e.g. Electronics" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Description" class="control-label"></label>
                    <textarea asp-for="Description" class="form-control" placeholder="Short description..." rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="form-divider"></div>

                <div class="form-actions">
                    <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="back-link">
                        <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                        Back to List
                    </a>
                    <button type="submit" class="btn-save">
                        <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                        Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}