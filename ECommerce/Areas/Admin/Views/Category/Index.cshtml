@model IReadOnlyList<CategoryListVM>
@{
    ViewData["Title"] = "Categories";
}

<div class="index-wrapper">

    <div class="index-topbar">
        <div>
            <h1>Categories</h1>
            <p>Manage and organize your store categories.</p>
        </div>
        <a asp-area="Admin" asp-controller="Category" asp-action="Create" class="btn-create">
            <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
            New Category
        </a>
    </div>

    <div class="category-table-card">
        <table class="category-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Created</th>
                    <th style="text-align:right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="4">
                            <div class="empty-state">
                                <svg viewBox="0 0 24 24">
                                    <rect x="2" y="3" width="20" height="14" rx="2" />
                                    <line x1="8" y1="21" x2="16" y2="21" />
                                    <line x1="12" y1="17" x2="12" y2="21" />
                                </svg>
                                <p>No categories yet. Create your first one!</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.Name</strong></td>
                            <td class="text-muted-cell">@item.Description</td>
                            <td class="date-cell">@item.CreateDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                <div class="table-actions">
                                    <a class="btn-action edit"
                                       asp-action="Edit"
                                       asp-area="Admin" asp-controller="Category"
                                       asp-route-id="@item.Id">
                                        <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
                                        Edit
                                    </a>
                                    <a class="btn-action delete"
                                       asp-action="Delete"
                                       asp-area="Admin" asp-controller="Category"
                                       asp-route-id="@item.Id">
                                        <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6" /><path d="M19 6l-1 14H6L5 6" /><path d="M10 11v6" /><path d="M14 11v6" /><path d="M9 6V4h6v2" /></svg>
                                        Delete
                                    </a>
                                    <a class="btn-action details"
                                       asp-action="Details"
                                       asp-area="Admin" asp-controller="Category"
                                       asp-route-id="@item.Id">
                                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                                        Details
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

</div>