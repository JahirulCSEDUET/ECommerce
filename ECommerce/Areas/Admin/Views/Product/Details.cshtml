@model ProductEditVM

@{
    ViewData["Title"] = "Product Details";
}


<div class="product-container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">Product Details</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Products</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
                </ol>
            </nav>
        </div>
        <div class="d-flex gap-2">
            <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary shadow-sm">
                <i class="bi bi-arrow-left me-2"></i>Back
            </a>
            <a asp-area="Admin" asp-controller="Product" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary shadow-sm">
                <i class="bi bi-pencil me-2"></i>Edit Product
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="row g-0">

            <div class="col-md-5 bg-light d-flex align-items-center justify-content-center p-4" style="min-height: 400px;">
                @if (!string.IsNullOrEmpty(Model.ImagePath))
                {
                    <img src="@Model.ImagePath" alt="@Model.Name" class="img-fluid rounded shadow-sm" style="max-height: 350px; object-fit: cover;" />
                }
                else
                {
                    <div class="text-center text-muted">
                        <div class="product-icon mx-auto mb-3" style="width: 80px; height: 80px; font-size: 2rem;">
                            @Model.Name.Substring(0, 1).ToUpper()
                        </div>
                        <p class="mb-0 small">No image uploaded</p>
                    </div>
                }
            </div>

            <div class="col-md-7">
                <div class="card-body p-5">

                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h3 class="fw-bold text-dark mb-1">@Model.Name</h3>
                            <div class="d-flex align-items-center gap-3 text-muted small">
                                <span><i class="bi bi-upc-scan me-1"></i> SKU: <strong class="text-dark">@Model.SKU</strong></span>
                                <span><i class="bi bi-folder2-open me-1"></i> Category ID: <strong class="text-dark">@Model.CategoryId</strong></span>
                            </div>
                        </div>
                        <div class="text-end">
                            <span class="fs-3 fw-bold text-success">$@Model.Price.ToString("N2")</span>
                        </div>
                    </div>

                    <hr class="text-light-subtle my-4" />

                    <div class="mb-4">
                        <h6 class="fw-bold text-uppercase text-muted mb-3" style="letter-spacing: 0.05em; font-size: 0.8rem;">Description</h6>
                        <p class="text-secondary lh-lg" style="white-space: pre-line;">@Model.Description</p>
                    </div>

                    <div class="bg-light p-3 rounded-3 mt-4">
                        <div class="row text-muted small">
                            <div class="col-6">
                                <span class="d-block fw-semibold text-dark mb-1">System ID</span>
                                #@Model.Id
                            </div>
                            <div class="col-6">
                                <span class="d-block fw-semibold text-dark mb-1">Image Path</span>
                                @(string.IsNullOrEmpty(Model.ImagePath) ? "N/A" : Model.ImagePath)
                            </div>
                        </div>
                    </div>
                    <div class="bg-light p-3 rounded-3 mt-4">
                        <div class="row text-muted small">
                            <div class="col-6">
                                <span class="d-block fw-semibold text-dark mb-1">Created Date</span>
                                @Model.CreatedDate.ToString("MMM dd, yyyy")
                            </div>
                            <div class="col-6">
                                <span class="d-block fw-semibold text-dark mb-1">Updated Date</span>
                                @* logic: If UpdateDate is null or default, show N/A, otherwise show the date *@
                                @(Model.UpdateDate == default(DateTime) ? "N/A" : Model.UpdateDate.ToString("MMM dd, yyyy"))
                            </div>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>
