@model ProductEditVM

@{
    ViewData["Title"] = "Edit Product";
}

<div class="product-container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">Edit Product</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Product" asp-action="Index" class="text-decoration-none">Products</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Edit</li>
                </ol>
            </nav>
        </div>
        <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary shadow-sm">
            <i class="bi bi-arrow-left me-2"></i>Back to Catalog
        </a>
    </div>

    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0" role="alert"></div>

        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ImagePath" /> @* Keep the old path if no new image is selected *@

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                        <h5 class="fw-bold mb-0">General Information</h5>
                    </div>
                    <div class="card-body p-4">

                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-semibold text-secondary">Product Name </label>
                            <input asp-for="Name" class="form-control form-control-lg bg-light border-0" placeholder="e.g. Wireless Headphones" />
                            <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-semibold text-secondary">Description </label>
                            <textarea asp-for="Description" class="form-control bg-light border-0" rows="5" placeholder="Describe the product..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3 mb-md-0">
                                <label asp-for="Price" class="form-label fw-semibold text-secondary">Base Price</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0 text-muted">$</span>
                                    <input asp-for="Price" type="number" step="0.01" class="form-control bg-light border-0" placeholder="0.00" />
                                </div>
                                <span asp-validation-for="Price" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="SKU" class="form-label fw-semibold text-secondary">SKU (Stock Keeping Unit) </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="bi bi-upc-scan text-muted"></i></span>
                                    <input asp-for="SKU" class="form-control bg-light border-0" placeholder="e.g. PROD-001" />
                                </div>
                                <span asp-validation-for="SKU" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-4">
                        <div class="mb-3">
                            <label asp-for="CategoryId" class="form-label fw-semibold text-secondary">Category </label>
                            <select asp-for="CategoryId" class="form-select bg-light border-0" asp-items="ViewBag.Categories">
                                <option value="">Select a Category</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-4">
                        <div class="mb-3">
                            <label class="form-label fw-semibold text-secondary">Product Image</label>

                            @* Image Display Container *@
                            <div id="imagePreviewContainer" class="bg-light d-flex align-items-center justify-content-center p-4 mb-3" style="min-height: 200px; border: 2px dashed #dee2e6; border-radius: 8px;">
                                @if (!string.IsNullOrEmpty(Model.ImagePath))
                                {
                                    <img id="imagePreview" src="@Model.ImagePath" alt="@Model.Name" class="img-fluid rounded shadow-sm" style="max-height: 250px; object-fit: cover;" />
                                }
                                else
                                {
                                    <div id="placeholderContent" class="text-center text-muted">
                                        <div class="product-icon mx-auto mb-3" style="width: 80px; height: 80px; font-size: 2rem; background-color: #e9ecef; display: flex; align-items: center; justify-content: center; border-radius: 50%;">
                                            @(string.IsNullOrEmpty(Model.Name) ? "?" : Model.Name.Substring(0, 1).ToUpper())
                                        </div>
                                        <p class="mb-0 small">No image uploaded</p>
                                    </div>
                                    @* Hidden img tag to be populated by JS when a file is selected *@
                                    <img id="imagePreview" src="#" alt="Preview" class="img-fluid rounded shadow-sm d-none" style="max-height: 250px; object-fit: cover;" />
                                }
                            </div>

                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-image text-muted"></i></span>
                                <input id="imageInput" name="ImageFile" type="file" accept=".jpg, .png, .jpeg" class="form-control bg-light border-0" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <input type="hidden" asp-for="CreatedDate" />
        <input type="hidden" asp-for="UpdateDate" />
        <div class="card border-0 shadow-sm mt-2">
            <div class="card-body p-4 d-flex justify-content-end gap-3">
                <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-light px-4">Cancel</a>
                <button type="submit" class="btn btn-primary px-5 shadow-sm">
                    <i class="bi bi-save me-2"></i>Update Product
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.getElementById('imageInput').onchange = function (evt) {
            const [file] = this.files;
            if (file) {
                const preview = document.getElementById('imagePreview');
                const placeholder = document.getElementById('placeholderContent');

                // Update the image source with the selected file
                preview.src = URL.createObjectURL(file);

                // Make sure the image is visible and placeholder is hidden
                preview.classList.remove('d-none');
                if (placeholder) {
                    placeholder.classList.add('d-none');
                }
            }
        };
    </script>
}