@model int

@{
    ViewData["Title"] = "Update Successful";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="mb-4">
                <div class="display-1 text-success">
                    <i class="bi bi-check-circle-fill"></i>
                </div>
            </div>
            <h1 class="fw-bold text-dark">Order Updated!</h1>
            <p class="text-muted fs-5">
                Order <strong>#@Model.ToString("D5")</strong> has been successfully marked as <strong>Delivered</strong>.
            </p>

            <hr class="my-4 opacity-25">

            <!-- Action Buttons -->
            <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                <a asp-action="Details" asp-route-id="@Model" class="btn btn-primary btn-lg px-4 rounded-pill shadow-sm">
                    <i class="bi bi-eye me-2"></i>View Order Details
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4 rounded-pill">
                    <i class="bi bi-list-ul me-2"></i>Back to List
                </a>
            </div>

            <p class="mt-5 text-muted small">
                Inventory and customer records have been updated accordingly.
            </p>
        </div>
    </div>
</div>

<style>
    /* Subtle entry animation */
    .container {
        animation: fadeIn 0.6s ease-out;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .display-1 i {
        filter: drop-shadow(0 4px 10px rgba(25, 135, 84, 0.2));
    }
</style>
