@model ECommerce.Presentation.Modules.Account.ViewModels.LoginVM

@{
    ViewData["Title"] = "Log In";
    var returnUrl = ViewData["ReturnUrl"];
}

<div class="flat-auth-wrapper">
    <div class="flat-auth-content">
        <div class="auth-header">
            <h2>Sign In</h2>
            <p>Welcome back. Please enter your details.</p>
        </div>

        <form asp-action="Login" method="post" class="auth-form" asp-route-returnUrl=@returnUrl>
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-input" placeholder="name@example.com" autofocus />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <div class="password-header">
                    <label asp-for="Password" class="form-label"></label>
                    <a href="/Account/ForgotPassword" class="forgot-password-link">Forgot password?</a>
                </div>
                <input asp-for="Password" class="form-input" placeholder="••••••••" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-group-checkbox">
                <label class="checkbox-label">
                    <input asp-for="RememberMe" class="checkbox-input" />
                    <span class="checkbox-text">@Html.DisplayNameFor(m => m.RememberMe)</span>
                </label>
            </div>

            <button type="submit" class="btn-submit">Sign In</button>
        </form>

        <div class="auth-footer">
            <p>Don't have an account? <a href="/Account/Register">Create one</a></p>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}