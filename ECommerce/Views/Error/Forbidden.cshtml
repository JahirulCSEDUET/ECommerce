@{
    ViewData["Title"] = "Access Forbidden";
}

<div class="forbidden-wrapper">
    <div class="forbidden-card">

        <div class="forbidden-top">
            <div class="forbidden-code">403</div>
            <div class="forbidden-icon-wrap">
                <svg viewBox="0 0 24 24">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                </svg>
            </div>
        </div>

        <div class="forbidden-body">
            <h1>Access Forbidden</h1>
            <p>
                You don't have permission to view this page.
                If you think this is a mistake, please contact your administrator.
            </p>
            <div class="notfound-actions">
                <a asp-action="Index" asp-controller="Home" class="btn-home">
                    <svg viewBox="0 0 24 24">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                        <polyline points="9 22 9 12 15 12 15 22" />
                    </svg>
                    Go Home
                </a>
                <a href="javascript:history.back()" class="btn-back-ghost">
                    <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                    Go Back
                </a>
            </div>
        </div>

        <div class="forbidden-footer">
            Error 403 — You are not authorized to access this resource.
        </div>

    </div>
</div>
