@{
    ViewData["Title"] = "Page Not Found";
}

<div class="notfound-wrapper">
    <div class="notfound-card">

        <div class="notfound-top">
            <div class="notfound-code">404</div>
            <div class="notfound-icon-wrap">
                <svg viewBox="0 0 24 24">
                    <circle cx="11" cy="11" r="8" />
                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                    <line x1="11" y1="8" x2="11" y2="12" />
                    <line x1="11" y1="16" x2="11.01" y2="16" />
                </svg>
            </div>
        </div>

        <div class="notfound-body">
            <h1>Page Not Found</h1>
            <p>
                The page you're looking for doesn't exist or may have been moved.
                Double-check the URL or head back to safety.
            </p>
            <div class="notfound-actions">
                <a asp-action="Index" asp-controller="Home" class="btn-home">
                    <svg viewBox="0 0 24 24">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                        <polyline points="9 22 9 12 15 12 15 22" />
                    </svg>
                    Go Home
                </a>
                <a href="javascript:history.back()" class="btn-back-ghost">
                    <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                    Go Back
                </a>
            </div>
        </div>

        <div class="notfound-footer">
            If you believe this is a mistake, please contact support.
        </div>

    </div>
</div>
