@using ECommerce.Presentation.Modules.Orders.ViewModels
@model IReadOnlyList<OrderListVM>

@{
    ViewData["Title"] = "Order Management";
}


<div class="order-list-container">
    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold mb-0 text-dark">Orders</h2>
                <p class="text-muted mb-0">Manage and track customer orders.</p>
            </div>
            <div>
                <span class="badge bg-secondary rounded-pill px-3 py-2 fs-6">
                    Total Orders: @Model.Count()
                </span>
            </div>
        </div>

        <div class="order-table-card">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th scope="col">Order ID</th>
                            <th scope="col">Date</th>
                            <th scope="col">Shipping Address</th>
                            <th scope="col">Total</th>
                            <th scope="col">Status</th>
                            <th scope="col" class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var order in Model)
                            {
                                // Determine the badge class based on the status string
                                string statusClass = order.Status?.ToLower() switch
                                {
                                    "pending" => "status-pending",
                                    "processing" => "status-processing",
                                    "shipped" => "status-shipped",
                                    "delivered" => "status-delivered",
                                    "cancelled" => "status-cancelled",
                                    _ => "bg-light text-dark" // Default fallback
                                };

                                <tr>
                                    <td class="fw-bold text-dark">
                                        #@order.Id.ToString("D5")
                                    </td>

                                    <td class="text-muted">
                                        @order.Orderdate.ToString("MMM dd, yyyy") <br />
                                        <small>@order.Orderdate.ToString("hh:mm tt")</small>
                                    </td>

                                    

                                    <td class="text-muted" title="@order.ShipAddress" style="max-width: 200px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                        @order.ShipAddress
                                    </td>

                                    <td class="fw-bold text-primary">
                                        @order.TotalAmount.ToString("C")
                                    </td>

                                    <td>
                                        <span class="status-badge @statusClass">
                                            @order.Status
                                        </span>
                                    </td>

                                    <td class="text-end">
                                        <a asp-area="" asp-controller="Order" asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-dark rounded-pill px-3">
                                            View
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <div class="text-muted">
                                        <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                                        <h5 class="fw-bold">No orders found</h5>
                                        <p>When customers place orders, they will appear here.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>