@using ECommerce.Presentation.Modules.Orders.ViewModels
@model OrderListVM

@{
    ViewData["Title"] = $"Order #{Model.Id:D5} Details";

    // Determine the badge class based on the status
    string statusClass = Model.Status?.ToLower() switch
    {
        "pending" => "status-pending",
        "processing" => "status-processing",
        "shipped" => "status-shipped",
        "delivered" => "status-delivered",
        "cancelled" => "status-cancelled",
        _ => "bg-light text-dark"
    };
}



<div class="container my-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3 mb-2">
                <i class="bi bi-arrow-left me-1"></i> Back to Orders
            </a>
            <h2 class="fw-bold text-dark mb-0">Order #@Model.Id.ToString("D5")</h2>
        </div>
        <div>
            <span class="status-badge @statusClass shadow-sm">
                <i class="bi bi-circle-fill small me-1"></i> @Model.Status
            </span>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-6">
            <div class="info-card shadow-sm">
                <h5 class="info-card-title"><i class="bi bi-receipt me-2"></i>Order Summary</h5>

                <div class="row">
                    <div class="col-sm-6">
                        <span class="info-label">Order Date</span>
                        <div class="info-value">@Model.Orderdate.ToString("MMM dd, yyyy")</div>
                    </div>
                    <div class="col-sm-6">
                        <span class="info-label">Order Time</span>
                        <div class="info-value">@Model.Orderdate.ToString("hh:mm tt")</div>
                    </div>
                    <div class="col-sm-6">
                        <span class="info-label">Payment Status</span>
                        <div class="info-value text-success"><i class="bi bi-check-circle-fill me-1"></i> Paid</div>
                    </div>
                    <div class="col-sm-6">
                        <span class="info-label">Total Amount</span>
                        <div class="info-value text-primary fs-5">@Model.TotalAmount.ToString("C")</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="info-card shadow-sm">
                <h5 class="info-card-title"><i class="bi bi-person-lines-fill me-2"></i>Shipping Address</h5>
                <div class="info-value mb-0">
                    <i class="bi bi-geo-alt text-muted me-1"></i>
                    @Model.ShipAddress
                </div>
            </div>
        </div>
    </div>

    <h4 class="fw-bold mb-3 border-bottom pb-2">Items in this Order</h4>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table item-table table-hover mb-0 align-middle">
                <thead>
                    <tr>
                        <th scope="col" class="ps-4">Product</th>
                        <th scope="col" class="text-center">Quantity</th>
                        <th scope="col" class="text-end">Unit Price</th>
                        <th scope="col" class="text-end pe-4">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.OrderItems != null && Model.OrderItems.Any())
                    {
                        foreach (var item in Model.OrderItems)
                        {
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-light rounded p-2 me-3">
                                            <i class="bi bi-box-seam text-secondary fs-5"></i>
                                        </div>
                                        <div>
                                            <h6 class="mb-0 fw-bold text-dark">
                                                <a asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId" class="text-decoration-none text-dark hover-primary">
                                                    @item.ProductName
                                                </a>
                                            </h6>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-center fw-semibold text-secondary py-3">
                                    x @item.Quantity
                                </td>
                                <td class="text-end text-muted py-3">
                                    @item.UnitPrice.ToString("C")
                                </td>
                                <td class="text-end fw-bold text-dark pe-4 py-3">
                                    @item.Subtotal.ToString("C")
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <i class="bi bi-exclamation-circle fs-2 d-block mb-2"></i>
                                No items found for this order.
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot class="bg-light">
                    <tr>
                        <td colspan="3" class="text-end fw-bold text-muted py-3">Grand Total:</td>
                        <td class="text-end fw-bold text-primary fs-5 pe-4 py-3">@Model.TotalAmount.ToString("C")</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

</div>