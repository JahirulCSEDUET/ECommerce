@model IReadOnlyList<ProductListVM>

@{
    ViewData["Title"] = "Premium E-Commerce Store";
}


<div class="container my-4">
    <div class="hero-section text-center shadow-lg">
        <h1 class="display-4 fw-bold mb-3">Elevate Your Lifestyle</h1>
        <p class="lead mb-4 opacity-75">Discover premium products tailored just for you. Shop the latest trends today.</p>
        <a href="#product-grid" class="btn btn-light btn-lg px-5 rounded-pill fw-bold text-primary shadow-sm">Explore Now</a>
    </div>

    <div class="d-flex justify-content-between align-items-end mb-4" id="product-grid">
        <div>
            <h2 class="fw-bold mb-0 text-dark">Trending Collections</h2>
            <p class="text-muted mb-0 mt-1">Carefully curated for quality and style.</p>
        </div>
        <span class="badge bg-light text-dark border px-3 py-2 rounded-pill shadow-sm">
            @Model.Count() Items
        </span>
    </div>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4 mb-5">
        @if (Model != null && Model.Any())
        {
            foreach (var product in Model)
            {
                <div class="col">
                    <div class="product-card h-100 d-flex flex-column">

                        <div class="product-img-wrapper">
                            <span class="category-badge text-uppercase">@product.CategoryName</span>

                            <img src="@(string.IsNullOrEmpty(product.ImagePath) ? "/images/no-image-placeholder.png" : product.ImagePath)"
                                 alt="@product.Name"
                                 class="product-img"
                                 onerror="this.src='/images/no-image-placeholder.png';" />
                        </div>

                        <div class="card-body d-flex flex-column p-4">
                            <div class="text-muted small mb-2 d-flex justify-content-between">
                                <span>SKU: @product.SKU</span>
                            </div>

                            <h5 class="card-title fw-bold text-dark text-truncate" title="@product.Name">@product.Name</h5>

                            <p class="card-text text-muted small flex-grow-1 mt-1">
                                @(string.IsNullOrEmpty(product.Description) ? "" : (product.Description.Length > 75 ? product.Description.Substring(0, 72) + "..." : product.Description))
                            </p>

                            <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
                                <span class="price-tag">@product.Price.ToString("C")</span>
                                <a asp-controller="Store" asp-action="Details" asp-route-id="@product.Id" class="btn btn-sm btn-outline-secondary rounded-pill px-3">Details</a>
                            </div>
                        </div>

                        <div class="px-4 pb-4 mt-auto">
                            <form asp-controller="Cart" asp-action="Add" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@product.Id" />
                                <input type="hidden" name="productName" value="@product.Name" />
                                <input type="hidden" name="unitPrice" value="@product.Price" />
                                <input type="hidden" name="quantity" value="1" />
                                <button type="submit" class="btn btn-cart w-100 py-2 fw-semibold d-flex justify-content-center align-items-center gap-2">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-cart2" viewBox="0 0 16 16">
                                        <path d="M0 2.5A.5.5 0 0 1 .5 2H2a.5.5 0 0 1 .485.379L2.89 4H14.5a.5.5 0 0 1 .485.621l-1.5 6A.5.5 0 0 1 13 11H4a.5.5 0 0 1-.485-.379L1.61 3H.5a.5.5 0 0 1-.5-.5zM3.14 5l1.25 5h8.22l1.25-5H3.14zM5 13a1 1 0 1 0 0 2 1 1 0 0 0 0-2zm-2 1a2 2 0 1 1 4 0 2 2 0 0 1-4 0zm9-1a1 1 0 1 0 0 2 1 1 0 0 0 0-2zm-2 1a2 2 0 1 1 4 0 2 2 0 0 1-4 0z" />
                                    </svg>
                                    Add to Cart
                                </button>
                            </form>
                            
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <h4 class="text-muted">No products found.</h4>
                <p>Check back later for new arrivals.</p>
            </div>
        }
    </div>
</div>