@model ProductEditVM
@{
    ViewData["Title"] = Model.Name + " - Details";
}

<div class="container my-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Store" asp-action="Index" class="text-decoration-none text-muted">Products</a></li>
            <li class="breadcrumb-item active fw-bold" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="product-details-container">
        <div class="row gx-5">

            <div class="col-lg-6 mb-4 mb-lg-0">
                <div class="product-image-gallery">
                    <img src="@(string.IsNullOrEmpty(Model.ImagePath) ? "/images/no-image-placeholder.png" : Model.ImagePath)"
                         alt="@Model.Name"
                         onerror="this.src='/images/no-image-placeholder.png';" />
                </div>
            </div>

            <div class="col-lg-6 d-flex flex-column">

                <h1 class="display-5 fw-bold text-dark mb-2">@Model.Name</h1>

                <div class="mb-4">
                    <span class="meta-info-pill">
                        <i class="bi bi-upc-scan me-1"></i> SKU: @Model.SKU
                    </span>
                    @* <span class="meta-info-pill">
                        <i class="bi bi-tags me-1"></i> Category ID: @Model.CategoryId
                    </span> *@
                </div>

                <div class="mb-4">
                    <span class="product-price-display">@Model.Price.ToString("C")</span>
                    <span class="text-muted ms-2">Excl. Tax</span>
                </div>

                <div class="mb-4 flex-grow-1">
                    <h5 class="fw-bold mb-2">About this product</h5>
                    <p class="text-secondary" style="line-height: 1.7;">
                        @Model.Description
                    </p>
                </div>

                <hr class="my-4">

                <div class="mb-4 action-buttons">
                    <form asp-controller="Cart" asp-action="Add" method="post" class="d-flex align-items-center gap-3">
                        <input type="hidden" name="productId" value="@Model.Id" />
                        <input type="hidden" name="productName" value="@Model.Name" />
                        <input type="hidden" name="unitPrice" value="@Model.Price" />

                        <div style="width: 100px;">
                            <label for="quantity" class="visually-hidden">Quantity</label>
                            <input type="number" id="quantity" name="quantity" class="form-control form-control-lg text-center fw-bold" value="1" min="1">
                        </div>

                        <div class="flex-grow-1">
                            <button type="submit" class="btn btn-dark btn-lg w-100 d-flex justify-content-center align-items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-cart-plus" viewBox="0 0 16 16">
                                    <path d="M9 5.5a.5.5 0 0 0-1 0V7H6.5a.5.5 0 0 0 0 1H8v1.5a.5.5 0 0 0 1 0V8h1.5a.5.5 0 0 0 0-1H9V5.5z" />
                                    <path d="M.5 1a.5.5 0 0 0 0 1h1.11l.401 1.607 1.498 7.985A.5.5 0 0 0 4 12h1a2 2 0 1 0 0 4 2 2 0 0 0 0-4h7a2 2 0 1 0 0 4 2 2 0 0 0 0-4h1a.5.5 0 0 0 .491-.408l1.5-8A.5.5 0 0 0 14.5 3H2.89l-.405-1.621A.5.5 0 0 0 2 1H.5zm3.915 10L3.102 4h10.796l-1.313 7h-8.17zM6 14a1 1 0 1 1-2 0 1 1 0 0 1 2 0zm7 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0z" />
                                </svg>
                                Add to Cart
                            </button>
                        </div>
                    </form>
                </div>

                @* <div class="d-flex justify-content-between system-info-text pt-3 border-top">
                    <span>Listed: @Model.CreatedDate.ToString("MMM dd, yyyy")</span>
                    <span>Last Updated: @Model.UpdateDate.ToString("MMM dd, yyyy")</span>
                </div> *@

            </div>
        </div>
    </div>
</div>